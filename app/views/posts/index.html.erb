<p style="color: green"><%= notice %></p>

<% content_for :title, "Tweets" %>

<div style="padding-left: 10px;">
  <h1 class="display-6">All Tweets</h1>
</div>

<div id="posts">
</div>

<table class="table table-striped">
  <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">Content</th>
      <th scope="col">Action</th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <th scope="row"><%= post.id %></th>
        <td><%= post.content %></td>
        <td><%= link_to "Details", post, class: "btn btn-outline-primary" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Create a tweet", new_post_path, class: "btn btn-outline-primary" %>
